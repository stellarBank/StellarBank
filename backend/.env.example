# Server
PORT=8000
NODE_ENV=development

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_string
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# SQLite (zero-setup local persistence — no Postgres/Docker required)
# SQLITE_DATA_DIR=./data
# SQLITE_DB_NAME=stellarbank.db

# Stellar / Soroban
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Set these after deploying contracts/remittance-pool (see contracts/README.md
# and the root README's "Deploying to testnet" section).
REMITTANCE_POOL_CONTRACT_ID=
TOKEN_A_CONTRACT_ID=
TOKEN_B_CONTRACT_ID=
